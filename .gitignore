```gitignore
# =========================
# Dependencies
# =========================
node_modules/
frontend/node_modules/

# =========================
# Next.js
# =========================
.next/
frontend/.next/
out/
frontend/out/

# =========================
# Build
# =========================
build/
dist/
bin/
tmp/

# =========================
# Environment
# =========================
.env
.env.*
backend/.env
frontend/.env

# =========================
# Logs
# =========================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Coverage
# =========================
coverage/

# =========================
# Uploads
# =========================
backend/uploads/*
!backend/uploads/.gitkeep

# =========================
# Vercel
# =========================
.vercel/

# =========================
# TypeScript
# =========================
*.tsbuildinfo
next-env.d.ts

# =========================
# Yarn / PnP
# =========================
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db

# =========================
# Air (Golang)
# =========================
.air.toml

# =========================
# Prisma
# =========================
/app/generated/prisma
```
# Archives 
*.rar *.zip *.7z